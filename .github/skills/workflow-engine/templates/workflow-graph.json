{
  "$schema": "../../../../tools/schemas/workflow-graph.schema.json",
  "description": "Multi-step Azure infrastructure workflow DAG with Bicep and Terraform tracks (governance as Step 3.5)",
  "nodes": {
    "step-1": {
      "id": "step-1",
      "type": "agent-step",
      "name": "Requirements",
      "agent": "02-Requirements",
      "requires": [],
      "produces": ["01-requirements.md", "sku-manifest.json", "sku-manifest.md"],
      "gate": "approval",
      "challenger": { "passes": 1, "lenses": ["comprehensive"] }
    },
    "gate-1": {
      "id": "gate-1",
      "type": "gate",
      "name": "Requirements Approval",
      "requires": ["step-1"],
      "gate": "approval"
    },
    "step-2": {
      "id": "step-2",
      "type": "agent-step",
      "name": "Architecture",
      "agent": "03-Architect",
      "requires": ["gate-1"],
      "produces": ["02-architecture-assessment.md", "03-des-cost-estimate.md", "03-des-sku-comparison.md"],
      "mutates": ["sku-manifest.json", "sku-manifest.md"],
      "gate": "approval",
      "challenger": {
        "default_passes": 1,
        "default_lenses": ["comprehensive"],
        "opt_in_multi_pass": true,
        "opt_in_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 3,
            "lenses": ["security-governance", "architecture-reliability", "cost-feasibility"]
          }
        }
      }
    },
    "gate-2": {
      "id": "gate-2",
      "type": "gate",
      "name": "Architecture Approval",
      "requires": ["step-2"],
      "gate": "approval"
    },
    "step-3": {
      "id": "step-3",
      "type": "agent-step",
      "name": "Design (optional)",
      "agent": "04-Design",
      "requires": ["gate-2"],
      "produces": ["03-des-diagram.drawio", "03-des-adr-*.md"],
      "gate": null,
      "optional": true,
      "challenger": {
        "default_passes": 0,
        "opt_in": true,
        "artifact_scope": "design-adr",
        "default_lenses": ["comprehensive"]
      }
    },
    "step-3_5": {
      "id": "step-3_5",
      "type": "agent-step",
      "name": "Governance",
      "agent": "04g-Governance",
      "requires": ["gate-2"],
      "produces": ["04-governance-constraints.md", "04-governance-constraints.json"],
      "gate": "approval",
      "challenger": {
        "default_passes": 1,
        "default_lenses": ["governance-reconciliation"],
        "skip_condition": "constraints.count == 0"
      }
    },
    "gate-2_5": {
      "id": "gate-2_5",
      "type": "gate",
      "name": "Governance Approval",
      "requires": ["step-3_5"],
      "gate": "approval",
      "preconditions": [
        {
          "id": "governance-reconciliation",
          "description": "Reconciliation review must be APPROVED before exit. If escalated_to_step-2, gate-2_5 stays closed until Architect re-approves and reconciliation re-runs APPROVED.",
          "check": "governance_trace.reconciliation_status != 'escalated_to_step-2'",
          "on_fail": "stay-at-step-3_5"
        }
      ]
    },
    "step-4": {
      "id": "step-4",
      "type": "agent-step",
      "name": "IaC Plan",
      "agent": "05-IaC Planner",
      "requires": ["gate-2_5"],
      "produces": [
        "04-implementation-plan.md",
        "04-implementation-plan.md#governance-compliance-matrix",
        "04-implementation-plan.md#code-generation-contract",
        "04-iac-contract.json",
        "04-policy-property-map.json",
        "04-environment-manifest.json",
        "04-dependency-diagram.py",
        "04-dependency-diagram.png",
        "04-runtime-diagram.py",
        "04-runtime-diagram.png"
      ],
      "mutates": ["sku-manifest.json", "sku-manifest.md"],
      "gate": "approval",
      "challenger": {
        "default_passes": 1,
        "default_lenses": ["comprehensive"],
        "opt_in_multi_pass": true,
        "opt_in_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          }
        },
        "exit_criteria": "all-passes-APPROVED"
      }
    },
    "gate-3": {
      "id": "gate-3",
      "type": "gate",
      "name": "Plan Approval",
      "requires": ["step-4"],
      "gate": "approval",
      "preconditions": [
        {
          "id": "plan-readiness",
          "description": "All plan-level challenger passes returned APPROVED. CodeGen agents (06b/06t) must not run plan-level adversarial review or self-edit 04-implementation-plan.md; any plan must_fix returns to step-4.",
          "check": "challenger.exit_criteria == 'all-passes-APPROVED' for step-4",
          "on_fail": "stay-at-step-4"
        },
        {
          "id": "plan-architecture-escalation",
          "description": "Anti-livelock: gate-3 may re-open when any step-4 finding has requires_step == 'step-2'. Control returns to 03-Architect via the step-4 → step-2 return_edge.",
          "check": "no step-4 challenger finding has requires_step == 'step-2'",
          "on_fail": "stay-at-step-4"
        }
      ]
    },
    "step-5b": {
      "id": "step-5b",
      "type": "agent-step",
      "name": "Bicep Code",
      "agent": "06b-Bicep CodeGen",
      "requires": ["gate-3"],
      "condition": { "field": "decisions.iac_tool", "equals": "Bicep" },
      "produces": ["infra/bicep/{project}/", "05-iac-handoff.json"],
      "gate": "validation",
      "plan_readonly": true,
      "frozen_inputs": [
        "04-implementation-plan.md",
        "04-iac-contract.json",
        "04-policy-property-map.json",
        "04-environment-manifest.json",
        "04-governance-constraints.md",
        "04-governance-constraints.json"
      ],
      "challenger": {
        "default_passes": 0,
        "opt_in": true,
        "artifact_scope": "iac-code",
        "opt_in_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 3,
            "lenses": ["security-governance", "architecture-reliability", "cost-feasibility"]
          }
        }
      }
    },
    "step-5t": {
      "id": "step-5t",
      "type": "agent-step",
      "name": "Terraform Code",
      "agent": "06t-Terraform CodeGen",
      "requires": ["gate-3"],
      "condition": { "field": "decisions.iac_tool", "equals": "Terraform" },
      "produces": ["infra/terraform/{project}/", "05-iac-handoff.json"],
      "gate": "validation",
      "plan_readonly": true,
      "frozen_inputs": [
        "04-implementation-plan.md",
        "04-iac-contract.json",
        "04-policy-property-map.json",
        "04-environment-manifest.json",
        "04-governance-constraints.md",
        "04-governance-constraints.json"
      ],
      "challenger": {
        "default_passes": 0,
        "opt_in": true,
        "artifact_scope": "iac-code",
        "opt_in_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 3,
            "lenses": ["security-governance", "architecture-reliability", "cost-feasibility"]
          }
        }
      }
    },
    "gate-4": {
      "id": "gate-4",
      "type": "gate",
      "name": "Code Validation",
      "requires": ["step-5b", "step-5t"],
      "requires_mode": "any",
      "gate": "validation"
    },
    "step-6b": {
      "id": "step-6b",
      "type": "agent-step",
      "name": "Bicep Deploy",
      "agent": "07b-Bicep Deploy",
      "requires": ["gate-4"],
      "condition": { "field": "decisions.iac_tool", "equals": "Bicep" },
      "produces": ["06-deployment-summary.md", "06-policy-precheck.json"],
      "mutates": ["sku-manifest.json", "sku-manifest.md"],
      "gate": "approval",
      "preconditions": [
        {
          "id": "governance-trace",
          "description": "L0→L1→L2→L3 attestation chain present in apex-recall decisions (key: governance_trace) before az deployment create / azd provision. Validator: validate-governance-trace.mjs.",
          "check": "decisions.governance_trace present at step-6 OR human-override decision recorded",
          "on_fail": "stay-at-step-6b"
        }
      ],
      "challenger": null
    },
    "step-6t": {
      "id": "step-6t",
      "type": "agent-step",
      "name": "Terraform Deploy",
      "agent": "07t-Terraform Deploy",
      "requires": ["gate-4"],
      "condition": { "field": "decisions.iac_tool", "equals": "Terraform" },
      "produces": ["06-deployment-summary.md", "06-policy-precheck.json"],
      "mutates": ["sku-manifest.json", "sku-manifest.md"],
      "gate": "approval",
      "preconditions": [
        {
          "id": "governance-trace",
          "description": "L0→L1→L2→L3 attestation chain present in apex-recall decisions (key: governance_trace) before terraform apply / azd provision. Validator: validate-governance-trace.mjs.",
          "check": "decisions.governance_trace present at step-6 OR human-override decision recorded",
          "on_fail": "stay-at-step-6t"
        }
      ],
      "challenger": null
    },
    "gate-5": {
      "id": "gate-5",
      "type": "gate",
      "name": "Deploy Approval",
      "requires": ["step-6b", "step-6t"],
      "requires_mode": "any",
      "gate": "approval"
    },
    "step-7": {
      "id": "step-7",
      "type": "subagent-fan-out",
      "name": "As-Built Documentation",
      "agent": "08-As-Built",
      "requires": ["gate-5"],
      "produces": [
        "07-design-document.md",
        "07-operations-runbook.md",
        "07-ab-cost-estimate.md",
        "07-compliance-matrix.md",
        "07-backup-dr-plan.md",
        "07-resource-inventory.md",
        "07-documentation-index.md"
      ],
      "mutates": ["sku-manifest.json", "sku-manifest.md"],
      "gate": null,
      "parallel_substeps": [
        "design-document",
        "operations-runbook",
        "cost-estimate",
        "compliance-matrix",
        "backup-dr-plan",
        "resource-inventory",
        "documentation-index"
      ]
    }
  },
  "edges": [
    { "from": "step-1", "to": "gate-1", "condition": "on_complete" },
    { "from": "gate-1", "to": "step-2", "condition": "on_complete" },
    { "from": "step-2", "to": "gate-2", "condition": "on_complete" },
    { "from": "gate-2", "to": "step-3", "condition": "on_complete" },
    { "from": "gate-2", "to": "step-3_5", "condition": "on_complete" },
    { "from": "step-3", "to": "step-3_5", "condition": "on_complete" },
    { "from": "step-3", "to": "step-3_5", "condition": "on_skip" },
    { "from": "step-3_5", "to": "gate-2_5", "condition": "on_complete" },
    { "from": "gate-2_5", "to": "step-4", "condition": "on_complete" },
    { "from": "step-4", "to": "gate-3", "condition": "on_complete" },
    { "from": "gate-3", "to": "step-5b", "condition": "on_complete" },
    { "from": "gate-3", "to": "step-5t", "condition": "on_complete" },
    { "from": "step-5b", "to": "gate-4", "condition": "on_complete" },
    { "from": "step-5t", "to": "gate-4", "condition": "on_complete" },
    { "from": "gate-4", "to": "step-6b", "condition": "on_complete" },
    { "from": "gate-4", "to": "step-6t", "condition": "on_complete" },
    { "from": "step-6b", "to": "gate-5", "condition": "on_complete" },
    { "from": "step-6t", "to": "gate-5", "condition": "on_complete" },
    { "from": "gate-5", "to": "step-7", "condition": "on_complete" }
  ],
  "return_edges": [
    {
      "from": "step-2",
      "to": "step-1",
      "condition": "on_refine",
      "reason": "Architect identifies requirement gaps — return for refinement",
      "ui_label_pattern": "^↩ Return to Step 1$"
    },
    {
      "from": "step-3",
      "to": "step-2",
      "condition": "on_refine",
      "reason": "Design step surfaces architecture re-evaluation needs",
      "ui_label_pattern": "^↩ Return to Step 2$"
    },
    {
      "from": "step-4",
      "to": "step-2",
      "condition": "on_refine",
      "reason": "IaC Planner finds architecture rework needed",
      "ui_label_pattern": "^↩ Return to Step 2$"
    },
    {
      "from": "step-4",
      "to": "step-2",
      "condition": "on_architecture_must_fix",
      "reason": "Anti-livelock: step-4 comprehensive finding requires architecture-level resolution (requires_step == 'step-2'). Closes the gate-3 all-passes-APPROVED livelock.",
      "ui_label_pattern": "^↩ Escalate to Architect$"
    },
    {
      "from": "step-3_5",
      "to": "step-2",
      "condition": "on_must_fix_governance_conflict",
      "reason": "Reconciliation review finds an approved-architecture-vs-newly-discovered-constraint conflict; 04g-Governance never self-edits 02-architecture-assessment.md.",
      "ui_label_pattern": "^↩ Reconcile with Architect$"
    },
    {
      "from": "step-4",
      "to": "step-3_5",
      "condition": "on_refine",
      "reason": "IaC Planner needs fresh governance discovery",
      "ui_label_pattern": "^▶ Refresh Governance$"
    },
    {
      "from": "step-5b",
      "to": "step-4",
      "condition": "on_refine",
      "reason": "Bicep CodeGen finds plan inadequate — return to planning",
      "ui_label_pattern": "^↩ Return to Step 4$"
    },
    {
      "from": "step-5t",
      "to": "step-4",
      "condition": "on_refine",
      "reason": "Terraform CodeGen finds plan inadequate — return to planning",
      "ui_label_pattern": "^↩ Return to Step 4$"
    },
    {
      "from": "step-6b",
      "to": "step-5b",
      "condition": "on_fail",
      "reason": "Bicep deployment failed — fix code and retry",
      "ui_label_pattern": "^↩ Fix Deployment Issues$"
    },
    {
      "from": "step-6b",
      "to": "step-2",
      "condition": "on_refine",
      "reason": "Bicep deployment surfaces architecture gap",
      "ui_label_pattern": "^↩ Return to Step 2$"
    },
    {
      "from": "step-6t",
      "to": "step-5t",
      "condition": "on_fail",
      "reason": "Terraform deployment failed — fix code and retry",
      "ui_label_pattern": "^↩ Fix Deployment Issues$"
    },
    {
      "from": "step-6t",
      "to": "step-2",
      "condition": "on_refine",
      "reason": "Terraform deployment surfaces architecture gap",
      "ui_label_pattern": "^↩ Return to Step 2$"
    },
    {
      "from": "step-1",
      "to": "step-1",
      "condition": "on_refine",
      "reason": "Requirements self-refinement loop",
      "ui_label_pattern": "^▶ Refine Requirements$"
    },
    {
      "from": "step-2",
      "to": "step-2",
      "condition": "on_refine",
      "reason": "Architect self-refinement loop (cost refresh, deep dive, SKU compare, save)",
      "ui_label_pattern": "^▶ (Refresh Cost Estimate|Deep Dive WAF Pillar|Compare SKU Options|Save Assessment)$"
    },
    {
      "from": "step-3_5",
      "to": "step-3_5",
      "condition": "on_refine",
      "reason": "Governance self-refresh loop",
      "ui_label_pattern": "^▶ Refresh Governance$"
    },
    {
      "from": "step-4",
      "to": "step-4",
      "condition": "on_refine",
      "reason": "IaC Planner self-refinement loop (revise plan, compare AVM)",
      "ui_label_pattern": "^▶ (Revise Plan|Compare AVM Modules)$"
    }
  ],
  "challenger": {
    "wrapper_agent": "10-Challenger",
    "review_subagent": "challenger-review-subagent"
  },
  "orchestrator_targets": ["01-Orchestrator"],
  "ui_pseudo_targets": ["agent"],
  "metadata": {
    "version": "2.3",
    "iac_tracks": ["Bicep", "Terraform"],
    "total_gates": 6,
    "total_steps": 7,
    "plan_lock": {
      "description": "Once gate-3 (Plan Approval) is passed, 04-implementation-plan.md (including the new Governance Compliance Matrix and Code-Generation Contract H2 sections), 04-governance-constraints.md, and 04-governance-constraints.json (including its discovery_metadata L0 envelope) are read-only for step-5b and step-5t. CodeGen agents that find plan-level must_fix issues MUST traverse the return_edge to step-4 (Planner) rather than self-edit the plan. Plan-level adversarial review (security-governance, architecture-reliability, cost-feasibility against the PLAN artifact) runs only at step-4; step-5* challenger passes use artifact_scope: iac-code. The four-layer governance attestation chain (L0 envelope → L1 plan matrix → L2 code attestation → L3 live precheck) is enforced end-to-end and audited via the apex-recall `governance_trace` decision before complete-step 6.",
      "frozen_artifacts": [
        "04-implementation-plan.md",
        "04-iac-contract.json",
        "04-policy-property-map.json",
        "04-environment-manifest.json",
        "04-governance-constraints.md",
        "04-governance-constraints.json"
      ],
      "plan_h2_sections": [
        "✅ ## 🛡️ Governance Compliance Matrix (L1 attestation)",
        "✅ ## 📤 Code-Generation Contract (frozen inputs for Step 5)"
      ],
      "attestation_chain": {
        "L0": "discovery_metadata envelope in 04-governance-constraints.json (owner: 04g-Governance)",
        "L1": "Governance Compliance Matrix H2 in 04-implementation-plan.md (owner: 05-IaC Planner)",
        "L2": "Per-row property attestation in *-validate-subagent output (owner: 06b/06t)",
        "L3": "policy-precheck-subagent live policy check (owner: 07b/07t)"
      }
    },
    "complexity_routing": {
      "description": "Deterministic formula for selecting challenger-review pass counts. Orchestrator computes `score` at gate-1, stores result in session state `decisions.complexity`, and agents read from session state instead of re-deriving. Weights calibrated on existing agent-output projects; adjust via PR with rationale.",
      "formula": "score = (resource_count / 3) + (policy_violations / 2) + (iac_tool == 'terraform' ? 0.5 : 0)",
      "tiers": [
        { "max_score": 1.5, "label": "simple", "passes": 1 },
        { "max_score": 3.0, "label": "standard", "passes": 2 },
        { "max_score": 999, "label": "complex", "passes": 3 }
      ],
      "inputs": {
        "resource_count": "Count of Azure resources declared in 02-architecture-assessment.md",
        "policy_violations": "Count of `deny`-effect findings from 04-governance-constraints.json",
        "iac_tool": "bicep or terraform, from decisions.iac_tool"
      }
    },
    "decision_toggles": {
      "description": "Project-scoped toggles set by 01-Orchestrator at session init. Each toggle has a default chosen to minimize latency/token cost; agents must honor session-state values when present. Read via `apex-recall show --json`; write via `apex-recall decide --key <toggle> --value <enum>`.",
      "toggles": {
        "governance_depth": {
          "enum": ["light", "full"],
          "default": "light",
          "description": "Controls policy-property-map and governance prose detail. Both modes MUST emit 04-policy-property-map.json covering every Deny policy; `light` omits non-Deny rationale prose only.",
          "owners": ["04g-Governance", "05-IaC Planner"]
        },
        "review_depth": {
          "enum": ["standard", "deep"],
          "default": "standard",
          "description": "`standard` runs single-pass comprehensive at mandatory gates. `deep` opts into multi-pass rotating lenses and enables Phase 4.5 challenger at step-5b/5t.",
          "owners": ["01-Orchestrator", "all challenger-invoking agents"]
        },
        "deployment_strategy": {
          "enum": ["single", "phased"],
          "default": "single",
          "description": "`single` is one `az deployment ... create` / `terraform apply`. `phased` splits into platform → workload → consumers with stop gates per `iac-common/references/deploy-shared-workflow.md`.",
          "owners": ["07b-Bicep Deploy", "07t-Terraform Deploy"]
        },
        "identity_resolution": {
          "enum": ["auto", "manual"],
          "default": "auto",
          "description": "`auto` resolves UAMIs and app registrations from session decisions + manifest. `manual` requires user to fill 04-environment-manifest.json fields before deploy. See azure-defaults/references/identity-resolution.md.",
          "owners": ["05-IaC Planner", "06b/06t CodeGen"]
        },
        "diagnostics_strategy": {
          "enum": ["avm", "module", "auto"],
          "default": "auto",
          "description": "`avm` uses AVM's built-in diagnosticSettings parameter (lowest token cost). `module` emits a separate `modules/diagnostics.bicep|tf`. `auto` picks `avm` when the AVM module supports it, else falls back to `module`.",
          "owners": ["06b/06t CodeGen"]
        },
        "entra_app_creation": {
          "enum": ["existing", "create"],
          "default": "existing",
          "description": "`existing` consumes pre-created app registrations from 04-environment-manifest.json (Graph blast radius zero). `create` requires Graph preflight (Application.ReadWrite.All) and lifecycle.prevent_destroy on the Terraform resource. See terraform-patterns/references/azuread-pattern.md.",
          "owners": ["05-IaC Planner", "06t Terraform CodeGen"]
        }
      }
    }
  }
}
