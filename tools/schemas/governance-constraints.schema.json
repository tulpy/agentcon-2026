{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jonathan-vella/azure-agentic-infraops/schemas/governance-constraints.schema.json",
  "title": "APEX Governance Constraints",
  "description": "Shape of agent-output/{project}/04-governance-constraints.json produced by 04g-Governance. Used by 06b/06t codegen agents and enforced in CI by scripts/validate-artifacts.mjs (Step 5b). The optional discovery_metadata envelope is the L0 attestation in the four-layer governance stack (L0 envelope → L1 plan matrix → L2 code attestation → L3 live precheck). discovery_metadata is warn-only for 30 days after rollout, then required.",
  "type": "object",
  "required": ["schema_version", "subscription_id", "discovered_at", "findings"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "governance-constraints-v1"
    },
    "subscription_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$|^unknown$"
    },
    "discovered_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "string",
      "enum": ["azure-policy-rest-api", "az-cli", "static", "partial", "github-actions-baseline"]
    },
    "discovery_metadata": {
      "description": "L0 attestation envelope. Mandatory after 30-day rollout window; warn-only before then. Every downstream consumer (05-IaC Planner, 06b/06t CodeGen, 07b/07t Deploy) reads this first and STOPS on staleness, signature drift, or non-COMPLETE status.",
      "type": "object",
      "required": [
        "discovery_status",
        "discovered_at",
        "scope",
        "api_versions",
        "page_counts",
        "completeness_signature",
        "ttl_days"
      ],
      "additionalProperties": true,
      "properties": {
        "discovery_status": {
          "type": "string",
          "enum": ["COMPLETE", "PARTIAL", "FAILED"]
        },
        "discovered_at": { "type": "string", "format": "date-time" },
        "scope": {
          "type": "object",
          "required": ["subscription_id", "management_groups"],
          "additionalProperties": true,
          "properties": {
            "subscription_id": {
              "type": "string",
              "pattern": "^[0-9a-fA-F-]{36}$|^unknown$"
            },
            "management_groups": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "api_versions": {
          "type": "object",
          "required": ["policyAssignments", "policyDefinitions"],
          "additionalProperties": { "type": "string" },
          "properties": {
            "policyAssignments": { "type": "string" },
            "policyDefinitions": { "type": "string" },
            "policyExemptions": { "type": "string" }
          }
        },
        "page_counts": {
          "type": "object",
          "required": ["policyAssignments", "policyDefinitions"],
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "properties": {
            "policyAssignments": { "type": "integer", "minimum": 0 },
            "policyDefinitions": { "type": "integer", "minimum": 0 },
            "policyExemptions": { "type": "integer", "minimum": 0 }
          }
        },
        "completeness_signature": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "ttl_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id", "display_name", "effect"],
        "additionalProperties": true,
        "properties": {
          "policy_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "effect": {
            "type": "string",
            "enum": ["deny", "audit", "auditIfNotExists", "append", "modify", "deployIfNotExists", "disabled"]
          },
          "scope": { "type": "string" },
          "azurePropertyPath": { "type": "string" },
          "bicepPropertyPath": { "type": "string" },
          "terraformPropertyPath": { "type": "string" },
          "required_value": {},
          "resource_types": { "type": "array", "items": { "type": "string" } },
          "override": {
            "type": ["object", "null"],
            "required": ["requested_at", "reason", "issue_link", "expiry"],
            "additionalProperties": false,
            "properties": {
              "requested_at": { "type": "string", "format": "date-time" },
              "requested_by": { "type": "string" },
              "reason": { "type": "string", "minLength": 8 },
              "issue_link": { "type": "string", "format": "uri" },
              "expiry": { "type": "string", "format": "date" }
            }
          }
        }
      }
    },
    "tags_required": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "allowed_values": { "type": "array", "items": { "type": "string" } },
          "default": { "type": "string" }
        }
      }
    },
    "allowed_locations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "policies": {
      "description": "Alias of findings — same array reference, emitted by discover.py for downstream consumers.",
      "type": "array",
      "items": { "$ref": "#/properties/findings/items" }
    }
  }
}
