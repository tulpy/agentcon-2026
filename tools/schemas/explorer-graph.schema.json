{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jonathan-vella/azure-agentic-infraops/schemas/explorer-graph.schema.json",
  "title": "APEX Architecture Explorer Graph",
  "description": "Shape of site/public/architecture-explorer-graph.json generated by scripts/generate-explorer-graph.mjs. Interactive architecture visualization data. Enforced by scripts/validate-explorer-graph.mjs.",
  "type": "object",
  "required": ["$schema", "generatedAt", "categories", "nodes", "edges"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "generatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of generation."
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "key", "label", "color", "shape", "count"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string" },
          "shape": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "label"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "label": { "type": "string" },
          "path": {
            "type": "string",
            "description": "Relative file path (must exist on disk)."
          },
          "description": { "type": "string" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "source": {
            "type": "string",
            "description": "Source node ID."
          },
          "target": {
            "type": "string",
            "description": "Target node ID."
          },
          "label": { "type": "string" }
        }
      }
    }
  }
}
