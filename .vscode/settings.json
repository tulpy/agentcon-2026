{
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": true,
  "chat.useClaudeMdFile": false,
  "chat.customAgentInSubagent.enabled": true,
  "chat.agentFilesLocations": {
    ".github/agents": true,
    ".github/agents/_subagents": true,
    "~/.copilot/agents": false,
    "~/.claude/agents": false
  },
  "chat.agentSkillsLocations": {
    ".github/skills": true,
    "~/.copilot/skills": false,
    "~/.claude/skills": false
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    "~/.copilot/instructions": false,
    "~/.claude/rules": false
  },
  "chat.hookFilesLocations": {
    ".github/hooks/tool-guardian": true,
    ".github/hooks/secrets-scanner": true,
    ".github/hooks/session-telemetry": true,
    ".github/hooks/subagent-validation": true,
    ".github/hooks/tool-audit": true
  },
  "chat.useCustomAgentHooks": true,
  "chat.useAgentSkills": true,
  "json.schemas": [
    {
      "fileMatch": ["tools/registry/agent-registry.json"],
      "url": "./tools/schemas/agent-registry.schema.json"
    },
    {
      "fileMatch": [".github/data/governance-policy-baseline.fixture.json"],
      "url": "./tools/schemas/governance-baseline.schema.json"
    },
    {
      "fileMatch": [".github/skills/vendor-prompting/rules.json"],
      "url": "./tools/schemas/vendor-prompting-rules.schema.json"
    },
    {
      "fileMatch": ["agent-output/*/09-lessons-learned.json"],
      "url": "./tools/schemas/lesson-log.schema.json"
    },
    {
      "fileMatch": ["agent-output/*/04-governance-constraints.json"],
      "url": "./tools/schemas/governance-constraints.schema.json"
    },
    {
      "fileMatch": [
        "agent-output/*/sku-manifest.json",
        ".github/skills/azure-artifacts/templates/sku-manifest.template.json"
      ],
      "url": "./tools/schemas/sku-manifest.schema.json"
    },
    {
      "fileMatch": ["agent-output/*/08-iteration-log.json", "agent-output/_bench/*/*/08-iteration-log.json"],
      "url": "./tools/schemas/iteration-log.schema.json"
    },
    {
      "fileMatch": ["tools/tests/drawio-golden/*/expected.json"],
      "url": "./tools/schemas/drawio-golden-scenario.schema.json"
    },
    {
      "fileMatch": ["tools/tests/drawio-baseline/_baseline-runs.json"],
      "url": "./tools/schemas/drawio-baseline-runs.schema.json"
    },
    {
      "fileMatch": ["tools/tests/drawio-baseline/regen-baseline.json"],
      "url": "./tools/schemas/drawio-regen-baseline.schema.json"
    }
  ],
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.rulers": [120],
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 120,
  "terminal.integrated.defaultProfile.linux": "bash",
  "files.eol": "\n",
  "editor.tabSize": 2,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.rulers": [120],
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120
  },
  "[bicep]": {
    "editor.tabSize": 2
  },
  "[terraform]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[powershell]": {
    "editor.tabSize": 4
  },
  "[python]": {
    "editor.tabSize": 4
  },
  "python.terminal.useEnvFile": true,
  "azureTerraform.checkTerraformCmd": false,
  "deno.enable": false,
  "deno.enablePaths": ["tools/mcp-servers/drawio"],
  "deno.lint": true,
  "deno.unstable": [],
  "chat.mcp.serverSampling": {
    "azure-agentic-infraops/.vscode/mcp.json: azure-mcp": {
      "allowedDuringChat": true
    }
  }
}
