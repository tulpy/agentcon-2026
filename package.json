{
  "name": "azure-agentic-infraops",
  "version": "0.10.0",
  "description": "APEX - Agentic Platform Engineering eXperience for Azure. Verified. Well-Architected. Deployable.",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:links": "find . -name '*.md' ! -path './node_modules/*' ! -path './infra/*' ! -path './site/node_modules/*' ! -path './site/dist/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "lint:links:docs": "find site/src/content/docs \\( -name '*.md' -o -name '*.mdx' \\) ! -path '*/demo/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check-site.json",
    "docs:dev": "cd site && npm run dev",
    "docs:build": "cd site && npm run build",
    "docs:preview": "cd site && npm run preview",
    "lint:site-links": "npm run docs:build --silent && node site/check-links.mjs",
    "validate:artifacts": "node tools/scripts/validate-artifacts.mjs",
    "fix:artifacts": "node tools/scripts/validate-artifacts.mjs --fix",
    "lint:artifact-templates": "node tools/scripts/validate-artifacts.mjs",
    "lint:h2-sync": "node tools/scripts/validate-artifacts.mjs",
    "fix:artifact-h2": "node tools/scripts/validate-artifacts.mjs --fix",
    "check:h2-order": "node tools/scripts/check-h2-order.mjs",
    "check:context-redundancy": "node tools/scripts/check-context-redundancy.mjs",
    "render:headings-summary": "node tools/scripts/render-headings-summary.mjs",
    "validate:headings-summary": "node tools/scripts/validate-headings-summary.mjs",
    "lint:version-sync": "node tools/scripts/validate-version-sync.mjs",
    "lint:deprecated-refs": "node tools/scripts/validate-no-deprecated-refs.mjs",
    "lint:mcp-config": "node tools/scripts/validate-mcp-config.mjs",
    "validate:extension-bloat": "node tools/scripts/validate-extension-bloat.mjs",
    "lint:docs-freshness": "node tools/scripts/check-docs-freshness.mjs",
    "lint:docs-frontmatter": "node tools/scripts/lint-docs-frontmatter.mjs",
    "validate:agents": "node tools/scripts/validate-agents.mjs",
    "lint:agent-frontmatter": "node tools/scripts/validate-agents.mjs",
    "lint:vendor-prompting": "node tools/scripts/validate-agents.mjs --only=vendor-prompting",
    "lint:workflow-handoffs": "node tools/scripts/validate-agents.mjs --only=workflow-handoffs",
    "test:vendor-prompting": "node --test tools/tests/vendor-prompting/run.test.mjs",
    "test:workflow-handoffs": "node --test tools/tests/workflow-handoffs/run.test.mjs",
    "lint:skills-format": "node tools/scripts/validate-skills.mjs",
    "lint:governance-refs": "node tools/scripts/validate-governance-refs.mjs",
    "test:governance-discovery": "python3 -m pytest .github/skills/azure-governance-discovery/scripts/test_discover.py -q",
    "validate:instruction-checks": "node tools/scripts/validate-instruction-checks.mjs",
    "validate:session-state": "node tools/scripts/validate-session-state.mjs",
    "lint:prose": "vale --config .vale.ini site/src/content/docs/ .github/ README.md || echo 'Vale not installed - run: brew install vale'",
    "lint:json": "node tools/scripts/lint-json.mjs",
    "lint:json-schemas": "node tools/scripts/validate-json-schemas.mjs",
    "lint:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) ! -path './node_modules/*' ! -path './infra/*' -exec yamllint -c .yamllint.yml {} \\; 2>/dev/null || echo 'yamllint not installed - run: pip install yamllint'",
    "lint:python": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check src/ tests/ && python3 -m ruff format --check src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check src/",
    "lint:python:fix": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check --fix src/ tests/ && python3 -m ruff format src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check --fix src/",
    "lint:python:types:warn": "cd tools/mcp-servers/azure-pricing && python3 -m mypy src/ || true",
    "lint:python:security:warn": "cd tools/mcp-servers/azure-pricing && python3 -m bandit -q -r -c pyproject.toml src/ || true",
    "test:apex-recall": "python3 -m pytest tools/tests/test_apex_recall/ -q",
    "test:subagent-file-contract": "node --test tools/tests/subagent-file-contract.test.mjs",
    "test:orphan-skill-discovery": "node --test tools/tests/orphan-skill-discovery.test.mjs",
    "test:sku-manifest": "node --test tools/tests/validate-sku-manifest.test.mjs",
    "test:sku-iac-coverage": "node --test tools/tests/validate-sku-iac-coverage.test.mjs",
    "test:derive-sku-allowlist": "node --test tools/tests/derive-sku-allowlist.test.mjs",
    "lint:safe-shell": "node tools/scripts/safe-shell.mjs",
    "lint:drawio": "node tools/scripts/validate-drawio-files.mjs",
    "lint:terraform-fmt": "terraform fmt -check -recursive infra/terraform/",
    "validate:terraform": "for dir in infra/terraform/*/; do [ -f \"$dir/main.tf\" ] && (cd \"$dir\" && terraform init -backend=false -input=false > /dev/null 2>&1 && terraform validate) || true; done",
    "validate:vscode": "node tools/scripts/validate-vscode-config.mjs",
    "fetch:deprecations": "node tools/scripts/fetch-azure-deprecations.mjs",
    "snapshot:baseline": "bash tools/scripts/snapshot-agent-context.sh",
    "diff:baseline": "bash tools/scripts/diff-context-baseline.sh",
    "profile:debug-log": "python3 tools/scripts/profile_debug_log.py",
    "smoke:verify": "python3 tools/scripts/smoke_verify.py",
    "validate:orchestrator-handoff": "python3 tools/scripts/validate_orchestrator_handoff.py",
    "validate:review-ceiling": "python3 tools/scripts/validate_review_ceiling.py",
    "validate:question-batching": "python3 tools/scripts/validate_question_batching.py",
    "lint:agent-checks": "node tools/scripts/validate-agents.mjs",
    "lint:glob-audit": "node tools/scripts/validate-glob-audit.mjs",
    "validate:model-consistency": "node tools/scripts/validate-model-consistency.mjs",
    "validate:deprecated-models": "node tools/scripts/validate-deprecated-models.mjs",
    "generate:model-catalog": "node tools/scripts/generate-model-catalog.mjs",
    "validate:model-catalog": "node tools/scripts/validate-model-catalog.mjs",
    "validate:skills": "node tools/scripts/validate-skills.mjs",
    "lint:skill-references": "node tools/scripts/validate-skills.mjs",
    "lint:orphaned-content": "node tools/scripts/validate-orphaned-content.mjs",
    "validate:workflow-graph": "node tools/scripts/validate-workflow-graph.mjs",
    "validate:challenger-findings": "node tools/scripts/validate-challenger-findings.mjs",
    "validate:challenger-presence": "node tools/scripts/validate-challenger-presence.mjs",
    "validate:challenger-decisions": "node tools/scripts/validate-challenge-findings-decisions.mjs --all",
    "validate:lens-references": "node tools/scripts/validate-lens-references.mjs",
    "report:challenger-gaps": "node tools/scripts/lessons-to-checklists.mjs",
    "challenger-telemetry": "node tools/scripts/challenger-telemetry.mjs",
    "lint:workflow-table-sync": "node tools/scripts/validate-workflow-table-sync.mjs",
    "validate:agent-registry": "node tools/scripts/validate-agent-registry.mjs",
    "validate:skill-checks": "node tools/scripts/validate-skill-checks.mjs",
    "validate:stale-refs": "node tools/scripts/validate-skills.mjs",
    "lint:model-alignment": "node tools/scripts/validate-agents.mjs",
    "e2e:validate": "node tools/scripts/validate-e2e-step.mjs all",
    "e2e:benchmark": "node tools/scripts/benchmark-e2e.mjs",
    "e2e:combine": "node tools/scripts/combine-e2e-runs.mjs",
    "export:agent-output-html": "python3 tools/scripts/export-agent-output-html.py",
    "init": "node tools/scripts/init-from-template.mjs",
    "setup": "bash tools/scripts/setup-azure.sh",
    "sync:workflows": "node tools/scripts/sync-workflows.mjs",
    "validate:no-hardcoded-counts": "node tools/scripts/validate-no-hardcoded-counts.mjs",
    "validate:hooks": "node tools/scripts/validate-hooks.mjs",
    "validate:iac-security-baseline": "node tools/scripts/validate-iac-security-baseline.mjs",
    "validate:iac-contract": "node tools/scripts/validate-iac-contract.mjs",
    "validate:iac-contract-consistency": "node tools/scripts/validate-iac-contract-consistency.mjs",
    "validate:avm-versions": "node tools/scripts/validate-avm-module-versions.mjs --mode=local",
    "validate:avm-versions:ci": "node tools/scripts/validate-avm-module-versions.mjs --mode=ci",
    "validate:avm-versions:freeze": "node tools/scripts/validate-avm-module-versions.mjs --mode=freeze",
    "validate:avm-versions:offline": "node tools/scripts/validate-avm-module-versions.mjs --mode=local --no-network",
    "validate:plan-avm-pins": "node tools/scripts/validate-plan-avm-pins.mjs --mode=freeze",
    "validate:plan-avm-pins:local": "node tools/scripts/validate-plan-avm-pins.mjs --mode=local",
    "refresh:avm-module-index": "node tools/scripts/refresh-avm-module-index.mjs",
    "refresh:avm-module-index:dry": "node tools/scripts/refresh-avm-module-index.mjs --no-version-refresh",
    "validate:policy-property-map": "node tools/scripts/validate-policy-property-map.mjs",
    "validate:environment-manifest": "node tools/scripts/validate-environment-manifest.mjs",
    "validate:iac-handoff": "node tools/scripts/validate-iac-handoff.mjs",
    "validate:tool-versions": "node tools/scripts/validate-tool-versions.mjs",
    "measure:baseline": "node tools/scripts/measure-workflow-baseline.mjs",
    "validate:policy-precheck": "node tools/scripts/validate-policy-precheck.mjs",
    "lint:policy-precheck": "node tools/scripts/validate-policy-precheck.mjs",
    "validate:sku-manifest": "node tools/scripts/validate-sku-manifest.mjs",
    "validate:sku-iac-coverage": "node tools/scripts/validate-sku-iac-coverage.mjs",
    "validate:decision-keys": "node tools/scripts/validate-decision-keys.mjs",
    "validate:banned-phrases": "node tools/scripts/validate-banned-phrases.mjs",
    "derive:sku-allowlist": "node tools/scripts/derive-sku-allowlist.mjs",
    "validate:terminology": "node tools/scripts/validate-terminology.mjs",
    "build:drawio-icons": "python3 tools/scripts/convert-azure-icons-to-drawio.py",
    "build:explorer-graph": "node tools/scripts/generate-explorer-graph.mjs",
    "validate:explorer-graph": "EXPLORER_GRAPH_STRICT=1 node tools/scripts/validate-explorer-graph.mjs",
    "validate:region-canonical": "node tools/scripts/validate-region-canonical.mjs",
    "test:hooks": "bash tools/tests/test-hooks.sh",
    "validate:governance-trace": "node tools/scripts/validate-governance-trace.mjs",
    "test:classify-model": "node --test tools/tests/validate-agents/classify-model.test.mjs",
    "test:drawio-mcp": "cd tools/mcp-servers/drawio && deno test -P --no-check",
    "test:convert-drawio-icons": "python3 -m pytest tools/tests/test_convert_drawio_icons.py -q",
    "test:azure-pricing-mcp": "python3 -m pytest tools/mcp-servers/azure-pricing/tests -q",
    "validate:_node": "run-p validate:artifacts validate:agents validate:orchestrator-handoff validate:review-ceiling validate:question-batching validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:extension-bloat validate:headings-summary validate:instruction-checks lint:governance-refs validate:session-state validate:workflow-graph validate:lens-references validate:challenger-findings validate:challenger-presence lint:workflow-table-sync lint:workflow-handoffs validate:agent-registry validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content lint:docs-freshness validate:no-hardcoded-counts validate:hooks validate:iac-security-baseline validate:policy-precheck validate:sku-manifest validate:sku-iac-coverage validate:decision-keys validate:banned-phrases validate:vscode lint:drawio validate:terminology validate:model-consistency validate:deprecated-models validate:model-catalog validate:explorer-graph validate:region-canonical test:classify-model lint:safe-shell validate:tool-versions",
    "validate:_node-ci": "run-p validate:artifacts validate:agents validate:orchestrator-handoff validate:review-ceiling validate:question-batching validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:extension-bloat validate:headings-summary lint:governance-refs validate:instruction-checks validate:session-state validate:workflow-graph validate:lens-references validate:challenger-findings validate:challenger-presence lint:workflow-table-sync lint:workflow-handoffs validate:agent-registry validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content validate:vscode lint:drawio validate:model-consistency validate:deprecated-models validate:model-catalog validate:explorer-graph validate:region-canonical test:classify-model validate:no-hardcoded-counts validate:terminology validate:sku-manifest validate:sku-iac-coverage validate:decision-keys validate:banned-phrases validate:policy-precheck lint:js:ci lint:safe-shell",
    "validate:_external": "run-p lint:md lint:python lint:terraform-fmt validate:terraform test:apex-recall test:azure-pricing-mcp lint:site-links",
    "validate:all": "run-p --continue-on-error validate:_node validate:_external && echo '✅ All validations passed'",
    "audit:quarterly": "run-p lint:glob-audit lint:orphaned-content lint:docs-freshness",
    "check:azure-icons-freshness": "node tools/scripts/check-azure-icons-freshness.mjs",
    "bench:drawio-quality": "node tools/scripts/run-drawio-quality-bench.mjs",
    "bench:drawio-diff": "node tools/scripts/render-golden-diff.mjs",
    "bench:azure-pricing": "cd tools/mcp-servers/azure-pricing && (./.venv/bin/python tests/fixtures/compact_bench.py 2>/dev/null || python3 tests/fixtures/compact_bench.py)",
    "lint:js": "eslint --cache --cache-location node_modules/.cache/eslint/ --quiet --format=compact",
    "lint:js:warnings": "eslint --cache --cache-location node_modules/.cache/eslint/ --format=compact",
    "lint:js:json": "eslint --cache --cache-location node_modules/.cache/eslint/ --quiet --format=json",
    "lint:js:ci": "npm run lint:js -- --max-warnings=0 tools/scripts tools/tests",
    "format": "prettier --write --cache --cache-location node_modules/.cache/prettier/ --log-level warn .",
    "format:check": "prettier --check --cache --cache-location node_modules/.cache/prettier/ --log-level warn .",
    "format:bicep": "bash tools/scripts/format-bicep-tree.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-n": "^18.0.1",
    "fast-xml-parser": "^5.8.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-vella/azure-agentic-infraops.git"
  },
  "keywords": [
    "azure",
    "bicep",
    "github-copilot",
    "infrastructure-as-code",
    "agents",
    "agentic",
    "well-architected",
    "azure-verified-modules"
  ],
  "author": "Jonathan Vella",
  "license": "MIT",
  "overrides": {
    "undici": ">=7.24.0",
    "dompurify": ">=3.3.2",
    "nanoid": ">=3.3.8",
    "mermaid": ">=11.4.1"
  },
  "engines": {
    "node": ">=22"
  }
}
